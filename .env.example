# Copy to .env and fill in what you need — everything is optional. chmod 600 .env (may contain secrets).

# Build-time toolchain flags: 1 = install, 0 = skip; re-run ./agentbox after changing. Always present: git, jq, tmux, python3, control plane.
# Node.js 22 + npm
INSTALL_NODE=1
# Bun
INSTALL_BUN=1
# Rust (rustup, cargo) — the heaviest layer
INSTALL_RUST=1
# Docker CLI + compose/buildx plugins
INSTALL_DOCKER=1
# GitHub CLI
INSTALL_GH=1
# GitLab CLI
INSTALL_GLAB=1
# Claude Code (needs INSTALL_NODE=1)
INSTALL_CLAUDE=1
# Playwright: headless Chromium + its system libs, for browser tests/screenshots (needs INSTALL_NODE=1)
INSTALL_PLAYWRIGHT=1
# Python dev tooling: pip + pipx + uv
INSTALL_PYTHON=0
# Go toolchain
INSTALL_GO=0
# Deno
INSTALL_DENO=0
# Ruby + bundler
INSTALL_RUBY=0
# ripgrep (rg), fd, fzf
INSTALL_SEARCH=0
# yq — YAML/JSON processor (companion to jq)
INSTALL_YQ=0
# shellcheck
INSTALL_SHELLCHECK=0
# DB clients: psql, sqlite3, redis-cli
INSTALL_DB_CLIENTS=0
# GitHub Copilot CLI (needs INSTALL_NODE=1)
INSTALL_COPILOT=0
# OpenAI Codex CLI (needs INSTALL_NODE=1)
INSTALL_CODEX=0
# Google Gemini CLI (needs INSTALL_NODE=1)
INSTALL_GEMINI=0
# Aider (needs INSTALL_PYTHON=1)
INSTALL_AIDER=0

# Git commit identity — defaults to "agentbox <agentbox@localhost>" if unset
GIT_USER_NAME=
GIT_USER_EMAIL=
# GitHub PAT (fine-grained, scoped) — enables git-over-HTTPS and gh via ~/.netrc
GITHUB_TOKEN=
# GitLab host (no scheme, no trailing slash) + PAT (api, write_repository) — set both to enable
GITLAB_HOST=
GITLAB_TOKEN=
# Private npm registry full URL + token — entrypoint writes ~/.npmrc, e.g. https://npm.pkg.github.com/
NPM_REGISTRY=
NPM_TOKEN=
# Optional: scope the registry to one org instead of making it the default, e.g. @myorg
NPM_SCOPE=
# Host dir copied into /home/dev on every start (read-only, perms preserved) — e.g. for .npmrc/.gitconfig/.ssh
SEED_HOME=
# Host dir copied into /work on every start (read-only)
SEED_WORK=
# Cloudflare Tunnel token — set to expose the control plane via a Zero Trust tunnel (cloudflared sidecar starts automatically)
CLOUDFLARE_TUNNEL_TOKEN=
# Control-plane login password — set to require a password (24h signed cookie); leave empty to leave auth to your proxy. Use a long, random value.
# Read once at control-plane startup: after changing it, restart so the new password takes effect (`docker compose restart agentbox`).
AGENTBOX_PASSWORD=
